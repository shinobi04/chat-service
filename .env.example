# Connection string for NeonDB Postgres
DATABASE_URL=postgresql://<user>:<password>@<ep-cool-db-123456.us-east-2.aws.neon.tech>/chat_db?sslmode=require

# Ollama connection string (use http://ollama:11434 when running in docker-compose)
OLLAMA_BASE_URL=http://ollama:11434

# Secret key for JWT signing (generate a strong random string in production)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me

# Redis connection string
REDIS_URL=redis://localhost:6379
